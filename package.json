{
  "name": "backend-analy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch workers/sync-worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "start:worker": "node dist/workers/sync-worker.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "migrate:dev": "prisma migrate dev --schema db/schema.prisma",
    "migrate:deploy": "prisma migrate deploy --schema db/schema.prisma",
    "prisma:generate": "prisma generate --schema db/schema.prisma",
    "gen-encryption-key": "node -e \"console.log('TOKEN_ENCRYPTION_KEY='+require('crypto').randomBytes(32).toString('base64'))\"",
    "gen-cookie-secret": "node -e \"console.log('SESSION_COOKIE_SECRET='+require('crypto').randomBytes(48).toString('base64'))\"",
    "pretest": "npm run prisma:generate",
    "prebuild": "npm run prisma:generate"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.2.2",
    "@prisma/client": "^6.2.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "googleapis": "^144.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
